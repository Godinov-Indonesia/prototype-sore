PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_prototype?schema=public"

# AI Engine Configurations
OPENAI_API_KEY="your-openai-api-key-here"

# Vector DB Configurations (Pinecone / Weaviate / Chroma)
VECTOR_DB_PROVIDER="pinecone"
PINECONE_API_KEY="your-pinecone-api-key-here"
PINECONE_ENVIRONMENT="us-east-1"
PINECONE_INDEX="prototype-index"

# Redis Configurations for Queue (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT=6379
